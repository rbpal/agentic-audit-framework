# .env.example
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────

# ─── Azure OpenAI (Layers 1–3 use this as the LLM backend) ───
AZURE_OPENAI_ENDPOINT=<https://your-resource.openai.azure.com/>
AZURE_OPENAI_API_KEY=<your-key-here>
AZURE_OPENAI_DEPLOYMENT_NAME=<your-deployment-name>       # e.g. gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21                       # Safe to commit — not a secret

# ─── Databricks (Step 2 materializes extraction to Delta) ────
DATABRICKS_HOST=<https://adb-xxxxxx.xx.azuredatabricks.net>
DATABRICKS_TOKEN=<your-pat-here>

# ─── MLflow (Step 11: experiment tracking) ───────────────────
MLFLOW_TRACKING_URI=<databricks or https://mlflow.yourorg.com>

# ─── OpenTelemetry (Step 10: tracing backend) ────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=<https://otel.yourorg.com:4317>

# ─── Azure identity (Step 9: Terraform & deploy targets) ─────
AZURE_SUBSCRIPTION_ID=<subscription-guid>
AZURE_TENANT_ID=<tenant-guid>

# ─── App config ──────────────────────────────────────────────
LOG_LEVEL=INFO                                            # DEBUG | INFO | WARNING | ERROR
